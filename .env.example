# Copia questo file in `.env.local` e compila i valori.
# `.env.local` non viene mai committato (vedi .gitignore).
# In produzione (Vercel/Netlify/etc.) configura queste stesse variabili
# nel pannello "Environment Variables" del provider.

# Resend — API key per l'invio email (https://resend.com/api-keys)
RESEND_API_KEY=

# Mittente delle email inviate dal form Contattaci.
# In sviluppo/free-tier Resend: "Vision <onboarding@resend.dev>"
# In produzione con dominio verificato: "Vision <noreply@tuodominio.it>"
CONTACT_FROM_EMAIL=

# Destinatario interno: dove arrivano le richieste compilate dagli utenti.
CONTACT_TO_EMAIL=
